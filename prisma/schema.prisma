// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma-client"
}

model Usuario {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  dispositivos Dispositivo[]
}

model Dispositivo {
  id           String   @id @default(uuid())
  credentialId String   @unique
  publicKey    String
  counter      Int
  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model MediaResource {
  id                 String       @id @default(uuid())
  imagenPrincipalUrl String
  nombre             String
  descripcion        String       @db.VarChar(150)
  instituto          String?
  miniaturaUrl       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  categorias         Categoria[]
  enlaces            Enlace[]
  vinetas            Vineta[]
}

model Categoria {
  id              String        @id @default(uuid())
  nombre          String
  mediaResourceId String
  mediaResource   MediaResource @relation(fields: [mediaResourceId], references: [id], onDelete: Cascade)
}

model Enlace {
  id              String        @id @default(uuid())
  tipo            String
  url             String
  mediaResourceId String
  mediaResource   MediaResource @relation(fields: [mediaResourceId], references: [id], onDelete: Cascade)
}

model Vineta {
  id              String        @id @default(uuid())
  comentario      String
  mediaResourceId String
  mediaResource   MediaResource @relation(fields: [mediaResourceId], references: [id], onDelete: Cascade)
}

model MetaDataResource {
  id          String   @id @default(uuid())
  metadatos   Json?    
}